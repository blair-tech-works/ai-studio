FROM node:22-alpine

WORKDIR /app

# Install git for worktree operations
RUN apk add --no-cache git

COPY package.json package-lock.json* ./
RUN npm install

COPY . .
RUN npm run build

# Create directories for agent worktrees and logs
RUN mkdir -p /tmp/ai-studio/worktrees /tmp/ai-studio/logs

EXPOSE 3001

CMD ["node", "dist/index.js"]
