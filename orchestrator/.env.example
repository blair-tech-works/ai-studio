DATABASE_URL=postgresql://ai_studio:ai_studio@localhost:5432/ai_studio
PORT=3001
AGENTS_CONFIG_PATH=../agents
TARGET_REPO_PATH=../target-project
LOG_LEVEL=debug

# --- PM agent (PRD drafting) auth ---
# Two modes; pick one:
#
# Mode A — OAuth via the `claude` CLI (free under your Claude subscription).
#   Leave ANTHROPIC_API_KEY empty. The orchestrator will spawn the CLI, which
#   uses your keychain OAuth tokens. REQUIRES starting the orchestrator from
#   a plain terminal — NOT from inside another Claude Code session, which
#   blocks nested CLI calls.
#
# Mode B — Direct API via the Anthropic SDK (works anywhere, billed per call).
#   Set ANTHROPIC_API_KEY=sk-ant-... and the orchestrator will skip the CLI
#   and use the SDK directly. Use this if you can't run outside Claude Code,
#   or for production deployments.
ANTHROPIC_API_KEY=
CLAUDE_CLI_PATH=claude
PM_MODEL=sonnet
